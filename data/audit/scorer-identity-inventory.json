    {
      "id": "RC1",
      "name": "UTF-8 Mojibake",
      "description": "Provider returns UTF-8 text but certain intermediaries/PHP serializers double-encode it as Latin-1. Two-byte UTF-8 sequences (C2-C5 + 80-BF) appear as two Latin-1 characters, e.g. ü (U+00FC, UTF-8 C3 BC) → Ã¼.",
      "fix": "fixMojibake() in lib/worldcup26Provider.ts — re-encodes Latin-1 codepoints as bytes, decodes as UTF-8.",
      "eventsAffected": 30
    },
    {
      "id": "RC2",
      "name": "Persian transliteration (worldcup26.ir)",
      "description": "worldcup26.ir stores player names in Persian script. Informal romanization: short vowels (a,e) dropped; 'و' (waw, representing u/o) → 'v'. Produces consonant-skeleton forms: Gonzalo → Gvnzalv, Holmgren → Hlmgrn.",
      "fix": "PLAYER_ALIASES in lib/worldcup26PlayerAliases.ts — constrained alias lookup from corrupted form to canonical name, scoped by scoring team.",
      "eventsAffected": 52
    },
    {
      "id": "RC3",
      "name": "Own-goal attribution error (provider)",
      "description": "Provider lists own-goal events without the (OG) marker, and sometimes attributes the event to the wrong player within the affected team. This causes isOwnGoal=false when it must be true, and playerTeamName=wrong.",
      "fix": "Full match replacement in lib/verifiedMatchEventCorrections.ts for each affected match.",
      "eventsAffected": 5
    }
  ],
